# 登录校验（仅服务端，勿用 NEXT_PUBLIC_）
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123

# 后端基址（BFF / SSR 直连）
BACKEND_URL=http://localhost:8080
# 浏览器端 API 基址（可选）：默认留空 = 同源 /api/*，勿填后端地址以免跨域丢 Cookie
# NEXT_PUBLIC_BROWSER_API_BASE=
# 刷新 JWT：POST body { "refreshToken" }，响应 data 含 accessToken / refreshToken / expiresIn / refreshIn


# 性能指标上报（sendBeacon POST JSON，默认同源 /api/performance/collect）
# NEXT_PUBLIC_PERF_REPORT_URL=/api/performance/collect
# 后端实际上报路径（默认 /api/performance/collect，与专用路由一致）
# BACKEND_PERF_COLLECT_PATH=/api/performance/collect
